# Firebase – kopier verdiene fra Firebase Console → Project Settings → Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth – fra Google Cloud Console → APIs & Services → Credentials
# Web Client ID er påkrevd (brukes av Firebase).
# iOS/Android Client ID er nødvendig for native builds.
# Expo Go bruker web client ID via nettleser-OAuth-flyt.
# Husk å legge til redirect URI i Google Cloud Console:
#   - exp://localhost:8081/--/auth  (Expo Go)
#   - familieportalen://auth        (produksjon)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
