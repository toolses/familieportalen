# Google Calendar OAuth
# Opprett credentials i Google Cloud Console > APIs & Services > Credentials
# Type: Web application — legg til redirect URI-en nedenfor som "Authorized redirect URI"
GOOGLE_CLIENT_ID=din_client_id_her.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=din_client_secret_her

# Valgfri — standardverdi er https://familieportalen-11d5e.web.app/google-callback
# GOOGLE_REDIRECT_URI=https://familieportalen-11d5e.web.app/google-callback

# Groq API (for skoleplan-funksjonen)
GROQ_API_KEY=din_groq_api_key_her
