rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Brukerpeker: kun brukeren selv kan lese/skrive (fcmTokens + householdId)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Husstandsdata: kun registrerte medlemmer kan lese og skrive
    match /households/{householdId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;

      // Eksisterende medlem gjør endringer
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.memberUids
        // Eller: ny bruker melder seg inn via gyldig invitasjonskode
        || (
          !resource.data.memberUids.hasAny([request.auth.uid])
          && request.resource.data.memberUids.hasAll(resource.data.memberUids)
          && request.auth.uid in request.resource.data.memberUids
          && exists(/databases/$(database)/documents/inviteCodes/$(resource.data.inviteCode))
        )
      );

      // Oppretting: brukeren må inkludere seg selv som medlem
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberUids;

      allow delete: if false;

      // Delte lister: kun husstandsmedlemmer
      match /lists/{listId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
      }

      // Dokumentarkiv: kun husstandsmedlemmer kan lese; slette kun opplaster eller admin
      match /documents/{docId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
        allow delete: if request.auth != null
          && (request.auth.uid == resource.data.uploadedBy
            || request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.adminUids);
        allow update: if false;
      }
    }

    // Invitasjonskoder: alle innloggede kan lese; kun husstandsmedlemmer kan opprette
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/households/$(request.resource.data.householdId)).data.memberUids;
      allow update, delete: if false;
    }

    // Delt kalender-konfigurasjon
    match /config/shared {
      allow read, write: if request.auth != null;
    }
  }
}
